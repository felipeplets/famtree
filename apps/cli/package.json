{
  "name": "@famtree/cli",
  "version": "0.1.1",
  "description": "CLI to render genogram JSON documents to SVG.",
  "type": "module",
  "license": "MIT",
  "author": "Felipe Plets",
  "keywords": [
    "genogram",
    "family-tree",
    "pedigree",
    "svg",
    "cli"
  ],
  "homepage": "https://github.com/felipeplets/famtree#readme",
  "bugs": "https://github.com/felipeplets/famtree/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felipeplets/famtree.git",
    "directory": "apps/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "famtree": "dist/cli.js"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "dependencies": {
    "@famtree/schema": "workspace:*",
    "@famtree/renderer": "workspace:*",
    "@famtree/validate": "workspace:*"
  },
  "peerDependencies": {
    "ajv": "8.20.0"
  },
  "peerDependenciesMeta": {
    "ajv": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
