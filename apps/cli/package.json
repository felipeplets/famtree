{
  "name": "@famtree/cli",
  "version": "0.1.0",
  "description": "CLI to render genogram JSON documents to SVG.",
  "type": "module",
  "license": "MIT",
  "author": "Felipe Plets",
  "keywords": ["genogram", "family-tree", "pedigree", "svg", "cli"],
  "homepage": "https://github.com/felipeplets/famtree#readme",
  "bugs": "https://github.com/felipeplets/famtree/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felipeplets/famtree.git",
    "directory": "apps/cli"
  },
  "publishConfig": { "access": "public" },
  "bin": {
    "famtree": "dist/cli.js"
  },
  "files": ["dist"],
  "dependencies": {
    "@famtree/schema": "workspace:0.1.0",
    "@famtree/renderer": "workspace:0.1.0",
    "@famtree/validate": "workspace:0.1.0"
  },
  "peerDependencies": {
    "ajv": "8.20.0"
  },
  "peerDependenciesMeta": {
    "ajv": { "optional": true }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
