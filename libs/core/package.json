{
  "name": "@famtree/core",
  "version": "0.1.1",
  "description": "Runtime-agnostic genogram engine: domain graph and layout.",
  "type": "module",
  "license": "MIT",
  "author": "Felipe Plets",
  "homepage": "https://github.com/felipeplets/famtree#readme",
  "bugs": "https://github.com/felipeplets/famtree/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felipeplets/famtree.git",
    "directory": "libs/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "README.md",
    "dist"
  ],
  "dependencies": {
    "@famtree/schema": "workspace:*"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
