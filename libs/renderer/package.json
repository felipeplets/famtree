{
  "name": "@famtree/renderer",
  "version": "0.1.0",
  "description": "SVG renderer for genogram documents.",
  "type": "module",
  "license": "MIT",
  "author": "Felipe Plets",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "dependencies": {
    "@famtree/schema": "workspace:*",
    "@famtree/core": "workspace:*"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test"
  }
}
