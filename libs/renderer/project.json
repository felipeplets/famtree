{
  "name": "@famtree/renderer",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/renderer/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "tsup", "cwd": "libs/renderer" },
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit -p tsconfig.json", "cwd": "libs/renderer" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "bun test", "cwd": "libs/renderer" }
    }
  }
}
