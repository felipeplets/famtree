{
  "name": "@famtree/validate",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/validate/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "tsup && tsc -p tsconfig.build.json", "cwd": "libs/validate" },
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit -p tsconfig.json", "cwd": "libs/validate" }
    }
  }
}
