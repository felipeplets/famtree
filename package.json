{
  "name": "famtree-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "NX monorepo for famtree — a genogram JSON Schema, renderer, and CLI.",
  "type": "module",
  "license": "MIT",
  "author": "Felipe Plets",
  "workspaces": ["libs/*", "apps/*"],
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck",
    "format": "prettier --write \"{libs,apps}/**/*.ts\"",
    "graph": "nx graph",
    "example": "bun apps/cli/src/cli.ts examples/example.genogram.json -o examples/genogram.svg"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "20.19.43",
    "ajv": "8.20.0",
    "nx": "23.1.0",
    "prettier": "3.9.5",
    "tsup": "8.5.1",
    "typescript": "7.0.2"
  }
}
