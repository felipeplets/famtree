{
  "name": "famtree-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "NX monorepo for famtree — a genogram JSON Schema, renderer, and CLI.",
  "type": "module",
  "license": "MIT",
  "author": "Felipe Plets",
  "workspaces": ["libs/*", "apps/*"],
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck",
    "format": "prettier --write \"{libs,apps}/**/*.ts\"",
    "graph": "nx graph",
    "example": "bun apps/cli/src/cli.ts examples/example.genogram.json -o examples/genogram.svg"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20",
    "ajv": "^8",
    "nx": "^20",
    "prettier": "^3.9.5",
    "tsup": "^8",
    "typescript": "^5"
  }
}
