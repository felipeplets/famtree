{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun", "node"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@famtree/schema": ["libs/schema/src/index.ts"],
      "@famtree/core": ["libs/core/src/index.ts"],
      "@famtree/renderer": ["libs/renderer/src/index.ts"],
      "@famtree/validate": ["libs/validate/src/index.ts"]
    }
  }
}
